rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEmployee() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee';
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isEmployee());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin() || isEmployee());
    }

    match /consultations/{consultationId} {
      allow create: if true; // Public can book
      allow read, update, delete: if isAdmin() || isEmployee();
    }

    match /system/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /notifications/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /transactions/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_directives/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_tasks/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_users/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_session_logs/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_notifications/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_approvals/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_profile_data/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingSlots/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingRequests/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingHistory/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingNotes/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingTasks/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /meetingNotifications/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_audit_logs/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_feedback/{document} {
      allow read: if true;
      allow write: if true;
    }

    match /ceo_download_logs/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
}